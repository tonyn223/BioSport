@model BioSport.Models.Membresia
@{
    ViewData["Title"] = "Mi Membresía";
}

<div class="container mt-4">
    <h1 class="text-success mb-4">Mi Membresía</h1>

    @if (Model == null)
    {
        <div class="alert alert-warning">
            Aún no tienes ninguna membresía activa. Consulta con recepción para adquirir un plan.
        </div>
    }
    else
    {
        var vencida = Model.FechaVencimiento < DateTime.Now;
        <div class="card shadow p-4" style="max-width: 600px;">
            <h4>@(Model.Plan?.Nombre ?? "N/A")</h4>
            <p class="text-muted">@Model.Plan?.Descripcion</p>
            <dl class="row">
                <dt class="col-sm-5">Precio:</dt>
                <dd class="col-sm-7">₡@Model.Plan?.Precio.ToString("N0")</dd>

                <dt class="col-sm-5">Fecha de Inicio:</dt>
                <dd class="col-sm-7">@Model.FechaInicio.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-5">Fecha de Vencimiento:</dt>
                <dd class="col-sm-7">@Model.FechaVencimiento.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-5">Estado:</dt>
                <dd class="col-sm-7">
                    @if (vencida)
                    {
                        <span class="badge bg-danger">Vencida</span>
                    }
                    else
                    {
                        <span class="badge bg-success">@Model.Estado</span>
                    }
                </dd>
            </dl>

            <hr />
            <h5>Tu Código de Acceso</h5>
            <h2 class="text-primary">@ViewBag.CodigoAcceso</h2>
            <p class="text-muted">Presenta este código en recepción para registrar tu asistencia.</p>
        </div>
    }

    <a asp-controller="Dashboard" asp-action="ClienteDashboard" class="btn btn-secondary mt-3">← Volver al Panel</a>
</div>
