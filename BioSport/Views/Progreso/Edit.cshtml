@model BioSport.Models.Progreso
@{
    ViewData["Title"] = "Editar Progreso";
}

<div class="container mt-4">
    <h1 class="text-info mb-4">Editar Progreso de @(Model.Cliente?.Nombre ?? "Cliente")</h1>

    <div class="card shadow p-4" style="max-width: 600px;">
        <form asp-action="Edit" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="mb-0">@error.ErrorMessage</p>
                    }
                </div>
            }

            <input type="hidden" asp-for="IdProgreso" />
            <input type="hidden" asp-for="IdCliente" />
            <input type="hidden" asp-for="IdEntrenador" />

            <div class="mb-3">
                <label class="form-label">Cliente</label>
                <input class="form-control" value="@(Model.Cliente?.Nombre ?? "N/A")" disabled />
            </div>

            <div class="mb-3">
                <label asp-for="Peso" class="form-label">Peso (kg)</label>
                <input asp-for="Peso" class="form-control" type="number" step="0.1" />
            </div>

            <div class="mb-3">
                <label asp-for="Observaciones" class="form-label">Observaciones</label>
                <textarea asp-for="Observaciones" class="form-control" rows="4"></textarea>
            </div>

            <button type="submit" class="btn btn-success">Guardar Cambios</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
