@model BioSport.Models.Progreso
@{
    ViewData["Title"] = "Registrar Progreso";
    var clientes = ViewBag.Clientes as List<BioSport.Models.Usuario>;
}

<div class="container mt-4">
    <h1 class="text-info mb-4">Registrar Progreso de Cliente</h1>

    <div class="card shadow p-4" style="max-width: 600px;">
        <form asp-action="Create" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="mb-0">@error.ErrorMessage</p>
                    }
                </div>
            }

            <div class="mb-3">
                <label asp-for="IdCliente" class="form-label">Cliente</label>
                <select asp-for="IdCliente" class="form-control">
                    <option value="">-- Selecciona un cliente --</option>
                    @if (clientes != null)
                    {
                        @foreach (var cliente in clientes)
                        {
                            <option value="@cliente!.IdUsuario">@cliente.Nombre</option>
                        }
                    }
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Peso" class="form-label">Peso (kg)</label>
                <input asp-for="Peso" class="form-control" type="number" step="0.1" />
            </div>

            <div class="mb-3">
                <label asp-for="Observaciones" class="form-label">Observaciones</label>
                <textarea asp-for="Observaciones" class="form-control" rows="4" placeholder="Ej: Buen progreso, mejoró resistencia..."></textarea>
            </div>

            <button type="submit" class="btn btn-success">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
