@model BioSport.Models.Plan
@{
    ViewData["Title"] = "Nuevo Plan";
}

<div class="container mt-4">
    <h1 class="text-primary mb-4">Crear Nuevo Plan</h1>

    <div class="card shadow p-4" style="max-width: 600px;">
        <form asp-action="Create" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="mb-0">@error.ErrorMessage</p>
                    }
                </div>
            }

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label">Nombre del Plan</label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: Plan Básico" />
            </div>

            <div class="mb-3">
                <label asp-for="Precio" class="form-label">Precio (₡)</label>
                <input asp-for="Precio" class="form-control" type="number" step="0.01" />
            </div>

            <div class="mb-3">
                <label asp-for="DuracionDias" class="form-label">Duración (días)</label>
                <input asp-for="DuracionDias" class="form-control" type="number" />
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label">Descripción</label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-success">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
