@{
    ViewData["Title"] = "Inicio";
    var horarios = ViewBag.Horarios as List<BioSport.Models.Horario>;
    var planes = ViewBag.Planes as List<BioSport.Models.Plan>;

    var ordenDias = new[] { "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo" };
    var horariosOrdenados = horarios?.OrderBy(h => Array.IndexOf(ordenDias, h.DiaSemana)).ToList();

    var diaHoy = ordenDias[((int)DateTime.Now.DayOfWeek + 6) % 7];
    var horarioHoy = horariosOrdenados?.FirstOrDefault(h => h.DiaSemana == diaHoy);
}

<!-- HERO -->
<div class="hero-biosport" style="--hero-img: url('@Url.Content("~/images/interior-panoramica.jpeg")');">
    <div class="hero-content">
        <div class="hero-hora">Abrimos a las 5:00 a.m. — todos los días</div>
        <h1>NUNCA ES<br />TARDE</h1>
        <p class="hero-slogan">"En nuestro gimnasio, somos una familia."</p>
        <div class="mt-4">
            <a href="https://wa.me/50685687154?text=Hola%2C%20me%20gustar%C3%ADa%20recibir%20informaci%C3%B3n" target="_blank" class="btn btn-success btn-lg me-2">Únete Ahora</a>
            <a href="#horarios" class="btn btn-outline-light btn-lg">Ver Horarios</a>
        </div>
    </div>
</div>

<!-- SOBRE NOSOTROS -->
<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <span class="eyebrow">Quiénes somos</span>
            <h2 class="mb-3 texto-acento">BioSport Gym</h2>
            <p class="fs-5">
                Creemos que cada persona merece la oportunidad de mejorar su calidad de vida,
                sin importar el punto de partida. Contamos con <strong>máquinas de todo tipo</strong> y un equipo
                de <strong>entrenadores personales certificados</strong> listos para acompañarte en cada paso de tu proceso.
            </p>
            <p class="fs-5">
                Más que un gimnasio, somos una familia que te impulsa a alcanzar tu mejor versión.
            </p>
        </div>
        <div class="col-md-6">
            <div class="about-panel"
                 style="--img: url('@Url.Content("~/images/interior-pesas.jpeg")');"
                 role="img" aria-label="Interior del gimnasio BioSport">
            </div>
        </div>
    </div>
</div>

<!-- GALERÍA -->
<div style="background-color: var(--concreto);" class="py-5 seccion-marca">
    <img src="~/images/logo-transparente.png" alt="" class="marca-agua" aria-hidden="true" />
    <div class="container">
        <span class="eyebrow">Instalaciones</span>
        <h2 class="mb-4 texto-acento">Así se entrena en BioSport</h2>

        <div class="galeria-carrusel">
            <button type="button" class="galeria-flecha galeria-flecha-prev" aria-label="Foto anterior">‹</button>
            <div class="galeria-track" id="galeria-instalaciones">
                <figure class="galeria-slide">
                    <button type="button" class="galeria-slide-btn" data-lightbox-src="@Url.Content("~/images/interior-zona-pesas.jpeg")" data-lightbox-alt="Zona de pesas del gimnasio BioSport">
                        <img src="~/images/interior-zona-pesas.jpeg"
                             class="galeria-slide-img" alt="Zona de pesas del gimnasio BioSport" loading="lazy" />
                    </button>
                    <figcaption class="foto-instalacion-label">Zona de pesas y máquinas</figcaption>
                </figure>
                <figure class="galeria-slide">
                    <button type="button" class="galeria-slide-btn" data-lightbox-src="@Url.Content("~/images/interior-maquinas.jpeg")" data-lightbox-alt="Área de máquinas del gimnasio BioSport">
                        <img src="~/images/interior-maquinas.jpeg"
                             class="galeria-slide-img" alt="Área de máquinas del gimnasio BioSport" loading="lazy" />
                    </button>
                    <figcaption class="foto-instalacion-label">Área de máquinas y cardio</figcaption>
                </figure>
            </div>
            <button type="button" class="galeria-flecha galeria-flecha-next" aria-label="Foto siguiente">›</button>
        </div>
    </div>
</div>

@{
    var promociones = ViewBag.Promociones as List<BioSport.Models.Promocion>;
}
@if (promociones != null && promociones.Any())
{
    <!-- PROMOCIONES -->
    <div style="background-color: var(--concreto);" class="py-5">
        <div class="container">
            <span class="eyebrow">Por tiempo limitado</span>
            <h2 class="mb-4 texto-acento">Promociones Activas</h2>
            <div class="row">
                @foreach (var promo in promociones)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card shadow plan-card h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h4 class="mb-0">@promo.Nombre</h4>
                                    @if (promo.DescuentoPorcentaje != null)
                                    {
                                        <span class="badge bg-danger">-@promo.DescuentoPorcentaje%</span>
                                    }
                                </div>
                                <p class="flex-grow-1">@promo.Descripcion</p>
                                <p class="text-muted font-mono mb-3">Válida hasta @promo.FechaFin.ToString("dd/MM/yyyy")</p>
                                <a href="https://wa.me/50685687154?text=Hola%2C%20me%20interesa%20la%20promoci%C3%B3n%20@promo.Nombre" target="_blank" class="btn btn-success mt-auto">Consultar</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- PLANES -->
<div class="container py-5">
    <span class="eyebrow">Membresías</span>
    <h2 class="mb-4 texto-acento">Nuestros Planes</h2>
    <div class="row">
        @if (planes != null)
        {
            @foreach (var plan in planes)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow plan-card h-100 text-center">
                        <div class="card-body d-flex flex-column">
                            <h4>@plan.Nombre</h4>
                            <div class="plan-precio">₡@plan.Precio.ToString("N0")</div>
                            <p class="text-muted font-mono">@plan.DuracionDias días</p>
                            <p class="flex-grow-1">@plan.Descripcion</p>
                            <a href="https://wa.me/50685687154?text=Hola%2C%20me%20gustar%C3%ADa%20recibir%20informaci%C3%B3n" target="_blank" class="btn btn-success mt-auto">Adquirir Plan</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- HORARIOS - LETRERO -->
<div id="horarios" style="background-color: var(--grafito);" class="py-5">
    <div class="container">
        <div class="text-center mb-4">
            <span class="eyebrow" style="color: var(--ambar);">Horario de Hoy: @diaHoy</span>
            <h2 style="color: var(--hueso);">
                @if (horarioHoy != null)
                {
                    <span class="font-mono">@horarioHoy.HoraApertura.ToString(@"hh\:mm") — @horarioHoy.HoraCierre.ToString(@"hh\:mm")</span>
                }
            </h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="letrero-horarios">
                    @if (horariosOrdenados != null)
                    {
                        @foreach (var h in horariosOrdenados)
                        {
                            <div class="fila-horario @(h.DiaSemana == diaHoy ? "hoy" : "")">
                                <span class="dia">@h.DiaSemana</span>
                                <span class="rango">@h.HoraApertura.ToString(@"hh\:mm") – @h.HoraCierre.ToString(@"hh\:mm")</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- UBICACIÓN Y CONTACTO -->
