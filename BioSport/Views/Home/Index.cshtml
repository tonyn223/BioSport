@{
    ViewData["Title"] = "Inicio";
    var horarios = ViewBag.Horarios as List<BioSport.Models.Horario>;
    var planes = ViewBag.Planes as List<BioSport.Models.Plan>;

    var ordenDias = new[] { "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo" };
    var horariosOrdenados = horarios?.OrderBy(h => Array.IndexOf(ordenDias, h.DiaSemana)).ToList();
}

<!-- HERO -->
<div class="text-white text-center d-flex align-items-center justify-content-center"
     style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://lh3.googleusercontent.com/gps-cs-s/AHRPTWnvs97Wb4WHyPLBwTHYWQ2TAOb7O7rLDjUTGNQtFZXjsOHNYgVNyTQQ0bbIeordRA-NQhjdvfQmn--2PGmxYcqda3udHzbnOQxqlwSEVpHnA-B1NMY6opmmJjo2L5XbSdwTI67A=s1360-w1360-h1020-rw') center/cover no-repeat; min-height: 480px;">
    <div>
        <h1 class="display-3 fw-bold">BioSport Gym</h1>
        <p class="fs-3 fst-italic">"Nunca es tarde para empezar"</p>
        <p class="fs-5 mb-4">En nuestro gimnasio, somos una familia.</p>
        <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-lg me-2">Únete Ahora</a>
        <a href="#horarios" class="btn btn-outline-light btn-lg">Ver Horarios</a>
    </div>
</div>

<!-- SOBRE NOSOTROS -->
<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h2 class="text-success mb-3">Sobre Nosotros</h2>
            <p class="fs-5">
                En BioSport Gym creemos que cada persona merece la oportunidad de mejorar su calidad de vida,
                sin importar el punto de partida. Contamos con <strong>máquinas de todo tipo</strong> y un equipo
                de <strong>entrenadores personales certificados</strong> listos para acompañarte en cada paso de tu proceso.
            </p>
            <p class="fs-5">
                Más que un gimnasio, somos una familia que te impulsa a alcanzar tu mejor versión.
            </p>
        </div>
        <div class="col-md-6">
            <img src="https://lh3.googleusercontent.com/gps-cs-s/AHRPTWkgh8hUP3RadxgbBYDNXu3dUuUz5PrdFhpsYh3C8_5fL-7aoc-PEScN3jpY62TS-kvvisgVihPlSimBqNSLh_DX-MBbmj02vxgUFTlWFYK42fnbuI74xbsNQrxwgV-j2YK9G8l2=s1360-w1360-h1020-rw"
                 class="img-fluid rounded shadow" alt="Interior del gimnasio BioSport" />
        </div>
    </div>
</div>

<!-- GALERÍA -->
<div class="bg-light py-5">
    <div class="container">
        <h2 class="text-center text-success mb-4">Nuestras Instalaciones</h2>
        <div class="row g-3">
            <div class="col-md-4">
                <img src="https://lh3.googleusercontent.com/gps-cs-s/AHRPTWnvs97Wb4WHyPLBwTHYWQ2TAOb7O7rLDjUTGNQtFZXjsOHNYgVNyTQQ0bbIeordRA-NQhjdvfQmn--2PGmxYcqda3udHzbnOQxqlwSEVpHnA-B1NMY6opmmJjo2L5XbSdwTI67A=s1360-w1360-h1020-rw"
                     class="img-fluid rounded shadow-sm" style="height:250px; width:100%; object-fit:cover;" alt="Área de entrenamiento 1" />
            </div>
            <div class="col-md-4">
                <img src="https://lh3.googleusercontent.com/gps-cs-s/AHRPTWkgh8hUP3RadxgbBYDNXu3dUuUz5PrdFhpsYh3C8_5fL-7aoc-PEScN3jpY62TS-kvvisgVihPlSimBqNSLh_DX-MBbmj02vxgUFTlWFYK42fnbuI74xbsNQrxwgV-j2YK9G8l2=s1360-w1360-h1020-rw"
                     class="img-fluid rounded shadow-sm" style="height:250px; width:100%; object-fit:cover;" alt="Área de entrenamiento 2" />
            </div>
            <div class="col-md-4">
                <img src="https://scontent.fsyq2-1.fna.fbcdn.net/v/t39.30808-6/612026024_1480516843643848_8573195569905798367_n.jpg?stp=dst-jpg_tt6&cstp=mx1080x1080&ctp=s1080x1080&_nc_cat=111&_nc_map=urlgen_bucketless&ccb=1-7&_nc_sid=127cfc&_nc_ohc=sD96sxVee4UQ7kNvwH3lepS&_nc_oc=Adrm27XN-9PvKzPN4y090Ratk2PxAgpgqCP9BPSyn_Ub0s4YeToSPEXQpcvGZdAuTc8&_nc_zt=23&_nc_ht=scontent.fsyq2-1.fna&_nc_gid=j9PV1EY2WQFaw5Z6-Fwp7A&_nc_ss=7b2a8&oh=00_AQDtlIHp3dVFGRXb8YdvexBUY8GgSzJUjMvPFTDCinkjYQ&oe=6A564DB0"
                     class="img-fluid rounded shadow-sm" style="height:250px; width:100%; object-fit:cover;" alt="Área de entrenamiento 3" />
            </div>
        </div>
    </div>
</div>

<!-- PLANES -->
<div class="container py-5">
    <h2 class="text-center text-success mb-4">Nuestros Planes</h2>
    <div class="row">
        @if (planes != null)
        {
            @foreach (var plan in planes)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow h-100 text-center">
                        <div class="card-body d-flex flex-column">
                            <h4 class="text-success">@plan.Nombre</h4>
                            <h2 class="fw-bold">₡@plan.Precio.ToString("N0")</h2>
                            <p class="text-muted">@plan.DuracionDias días</p>
                            <p class="flex-grow-1">@plan.Descripcion</p>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-success mt-auto">Adquirir Plan</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- HORARIOS -->
<div id="horarios" class="bg-dark text-white py-5">
    <div class="container">
        <h2 class="text-center mb-4">Horarios de Atención</h2>
        <div class="row justify-content-center">
            <div class="col-md-6">
                <table class="table table-dark table-striped">
                    <tbody>
                        @if (horariosOrdenados != null)
                        {
                            @foreach (var h in horariosOrdenados)
                            {
                                <tr>
                                    <td class="fw-bold">@h.DiaSemana</td>
                                    <td>@h.HoraApertura.ToString(@"hh\:mm") - @h.HoraCierre.ToString(@"hh\:mm")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- UBICACIÓN Y CONTACTO -->
<div class="container py-5">
    <div class="row">
        <div class="col-md-6 mb-4">
            <h2 class="text-success mb-3">Ubicación</h2>
            <p class="fs-5">
                225 metros de la Municipalidad de Moravia, camino al estadio.<br />
                San Vicente, Moravia, San José, Costa Rica.
            </p>
            <div class="ratio ratio-16x9">
                <iframe
                    src="https://www.google.com/maps?q=9.963361,-84.047639&z=17&output=embed"
                    style="border:0;" allowfullscreen loading="lazy">
                </iframe>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <h2 class="text-success mb-3">Contáctanos</h2>
            <ul class="list-unstyled fs-5">
                <li class="mb-3">
                    <strong>📞 Teléfono:</strong> 8772-0832
                </li>
                <li class="mb-3">
                    <strong>✉️ Correo:</strong> bio-sport@hotmail.com
                </li>
                <li class="mb-3">
                    <strong>📘 Facebook:</strong>
                    <a href="https://www.facebook.com/p/Gimnasio-Bio-Sport-100050566386030/?locale=es_LA" target="_blank">
                        Gimnasio Bio Sport
                    </a>
                </li>
            </ul>
            <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-lg mt-3">¡Únete a la Familia BioSport!</a>
        </div>
    </div>
</div>
