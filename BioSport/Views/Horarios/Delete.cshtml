@model BioSport.Models.Horario
@{
    ViewData["Title"] = "Eliminar Horario";
}

<div class="container mt-4">
    <h1 class="text-danger mb-4">Eliminar Horario</h1>

    <div class="card shadow p-4" style="max-width: 600px;">
        <p>¿Estás seguro que deseas eliminar este horario?</p>
        <dl class="row">
            <dt class="col-sm-4">Día:</dt>
            <dd class="col-sm-8">@Model.DiaSemana</dd>
            <dt class="col-sm-4">Horario:</dt>
            <dd class="col-sm-8">@Model.HoraApertura.ToString(@"hh\:mm") - @Model.HoraCierre.ToString(@"hh\:mm")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IdHorario" />
            <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
