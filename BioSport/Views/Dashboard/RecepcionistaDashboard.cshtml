@{
    ViewData["Title"] = "Panel Recepcionista";
}

<div class="container mt-4">
    <h1 class="text-info mb-4">Panel Recepcionista</h1>
    <p class="text-muted">Bienvenido, @User.Identity!.Name</p>
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h5>Registrar Asistencia</h5>
                    <a asp-controller="Asistencia" asp-action="Registrar" class="btn btn-success">Ir</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h5>Registrar Pagos</h5>
                    <a href="#" class="btn btn-danger">Ir</a>
                </div>
            </div>
        </div>
    </div>
</div>
