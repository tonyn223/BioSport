@model IEnumerable<BioSport.Models.Promocion>
@{
    ViewData["Title"] = "Gestionar Promociones";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary">Gestionar Promociones</h1>
        <a asp-action="Create" class="btn btn-success">+ Nueva Promoción</a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    <table class="table table-striped shadow">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Descuento</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var promo in Model)
            {
                <tr>
                    <td>@promo.Nombre</td>
                    <td>@promo.DescuentoPorcentaje%</td>
                    <td>@promo.FechaInicio.ToString("dd/MM/yyyy")</td>
                    <td>@promo.FechaFin.ToString("dd/MM/yyyy")</td>
                    <td>
                        <span class="badge bg-@(promo.Estado == "Activo" ? "success" : "secondary")">
                            @promo.Estado
                        </span>
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@promo.IdPromocion" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@promo.IdPromocion" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-controller="Dashboard" asp-action="AdminDashboard" class="btn btn-secondary">← Volver al Panel</a>
</div>
