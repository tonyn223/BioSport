@model BioSport.Models.Rutina
@{
    ViewData["Title"] = "Eliminar Rutina";
}

<div class="container mt-4">
    <h1 class="text-danger mb-4">Eliminar Rutina</h1>

    <div class="card shadow p-4" style="max-width: 600px;">
        <p>¿Estás seguro que deseas eliminar esta rutina? También se eliminarán sus asignaciones a clientes.</p>
        <dl class="row">
            <dt class="col-sm-4">Nombre:</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>
            <dt class="col-sm-4">Descripción:</dt>
            <dd class="col-sm-8">@Model.Descripcion</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="IdRutina" />
            <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
