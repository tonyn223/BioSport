@{
    ViewData["Title"] = "Asignar Rutina";
    var rutina = ViewBag.Rutina as BioSport.Models.Rutina;
    var clientes = ViewBag.Clientes as List<BioSport.Models.Usuario>;
}

<div class="container mt-4">
    <h1 class="text-warning mb-4">Asignar Rutina a Cliente</h1>

    <div class="card shadow p-4" style="max-width: 600px;">
        <h5>Rutina: @rutina?.Nombre</h5>
        <p class="text-muted">@rutina?.Descripcion</p>
        <hr />

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Selecciona el Cliente</label>
                <select name="idCliente" class="form-control" required>
                    <option value="">-- Selecciona un cliente --</option>
                    @if (clientes != null)
                    {
                        @foreach (var cliente in clientes)
                        {
                            <option value="@cliente.IdUsuario">@cliente.Nombre (@cliente.Email)</option>
                        }
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-primary">Asignar Rutina</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
